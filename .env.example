# FightLog - Umgebungskonfiguration
# Kopiere diese Datei nach .env und passe die Werte an

# Datenbank
DB_HOST=127.0.0.1
DB_USER=root
DB_PASS=
DB_NAME=fightlog
DB_CHARSET=utf8mb4

# Optional: Produktionsmodus (true/false)
PRODUCTION_MODE=false

# Optional: Erlaubte CORS-Origins (kommagetrennt)
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Optional: App-URL für E-Mails
# APP_URL=http://localhost

# Optional: Domain für Passkey-Registrierung (z.B. localhost oder fightlog.example.com)
# APP_DOMAIN=localhost
