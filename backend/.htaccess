# Apache-Konfiguration für FightLog Backend API
# Ermöglicht Authorization-Header für Bearer Token Auth

# METHODE 1: RewriteRule für mod_rewrite
<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Authorization-Header an PHP weiterleiten
    RewriteCond %{HTTP:Authorization} ^(.*)
    RewriteRule .* - [e=HTTP_AUTHORIZATION:%1]
    
    # OPTIONS preflight requests
    RewriteCond %{REQUEST_METHOD} OPTIONS
    RewriteRule ^(.*)$ $1 [R=200,L]
</IfModule>

# METHODE 2: SetEnvIf für CGI/FastCGI
<IfModule mod_setenvif.c>
    SetEnvIf Authorization "(.*)" HTTP_AUTHORIZATION=$1
</IfModule>

# METHODE 3: CGI PassEnv
<IfModule mod_cgi.c>
    PassEnv HTTP_AUTHORIZATION
</IfModule>

# PHP-spezifisch: Header direkt übergeben
<IfModule mod_php.c>
    SetEnv HTTP_AUTHORIZATION %{HTTP:Authorization}
</IfModule>

# CORS für API-Zugriffe
<IfModule mod_headers.c>
    Header always set Access-Control-Allow-Origin "*"
    Header always set Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
    Header always set Access-Control-Allow-Headers "Authorization, X-Authorization, Content-Type, X-CSRF-Token"
    Header always set Access-Control-Expose-Headers "Authorization"
</IfModule>
